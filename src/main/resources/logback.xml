<configuration>
	<appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>%d{YYYY-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
		</encoder>
	</appender>
	<root level="info">
		<appender-ref ref="STDOUT"/>
	</root>
	<logger name="org.eclipse.jetty" level="WARN"/>
	<logger name="io.netty" level="WARN"/>
	<logger name="uk.me.cormack.lighting7.midi" level="debug"/>
	<!-- JmDNS 3.5.x does not understand DNS record type 65 (HTTPS/SVCB, RFC 9460);
	     suppress the harmless WARN it emits whenever a browser or the system
	     mDNSResponder asks for one. -->
	<logger name="javax.jmdns.impl.DNSIncoming" level="ERROR"/>
	<logger name="javax.jmdns.impl.constants.DNSRecordType" level="ERROR"/>
</configuration>
